# ---- Zerodha Kite Connect credentials ----
# Get these from https://developers.kite.trade/apps
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Generated daily by: python generate_token.py
KITE_ACCESS_TOKEN=

# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017
MONGO_DB=past_data
MONGO_COLLECTION=hourly_futures

# ---- Backfill settings ----
YEARS_BACK=10
# Delay between API calls in seconds (Kite allows ~3/sec, we use 0.4s to be safe)
REQUEST_DELAY=0.4
